{
  "name": "@rotki/eslint-plugin",
  "version": "1.3.2",
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916",
  "type": "module",
  "license": "AGPL-3.0",
  "bugs": {
    "url": "https://github.com/rotki/eslint-plugin/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rotki/eslint-plugin.git"
  },
  "author": "Rotki Solutions GmbH <info@rotki.com>",
  "files": [
    "dist"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf .nyc_output coverage dist docs/.vitepress/dist",
    "coverage": "nyc report --reporter lcov && opener coverage/lcov-report/index.html",
    "generate": "tsx scripts/update-rule-docs.ts",
    "generate:index": "tsx scripts/update-docs-index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "unbuild",
    "dev": "unbuild --stub",
    "prepublishOnly": "pnpm run build",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "new": "tsx ./scripts/new-rule.ts",
    "docs": "vitepress dev docs",
    "docs:build": "pnpm run generate && pnpm run generate:index && vitepress build docs",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "release": "bumpp -r --no-push"
  },
  "peerDependencies": {
    "eslint": "^9.20.0"
  },
  "dependencies": {
    "@typescript-eslint/utils": "8.60.1",
    "debug": "4.4.3",
    "jsonc-eslint-parser": "3.1.0",
    "scule": "1.3.0",
    "tinyglobby": "0.2.17",
    "vue-eslint-parser": "10.4.1",
    "yaml-eslint-parser": "2.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@rotki/eslint-config": "6.1.0",
    "@rotki/eslint-plugin": "1.3.2",
    "@types/debug": "4.1.13",
    "@types/node": "24.13.1",
    "@typescript-eslint/eslint-plugin": "8.60.1",
    "@typescript-eslint/parser": "8.60.1",
    "@typescript-eslint/rule-tester": "8.60.1",
    "@vitest/coverage-v8": "4.1.8",
    "bumpp": "11.1.0",
    "eslint": "9.39.4",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "unbuild": "3.6.1",
    "vitepress": "1.6.4",
    "vitest": "4.1.8"
  },
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10 <12"
  },
  "lint-staged": {
    "*.{js,cjs,ts,vue,yml,json,md}": "eslint"
  }
}
