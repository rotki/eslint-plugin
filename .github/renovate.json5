{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":dependencyDashboardApproval",
    ":pinAllExceptPeerDependencies",
    "helpers:pinGitHubActionDigests"
  ],
  "minimumReleaseAge": "7 days",
  "packageRules": [
    {
      "allowedVersions": "/^(24)\\./",
      "groupName": "Node.js",
      "matchPackageNames": ["@types/node", "node"]
    }
  ]
}
